# Garrón — variables de entorno
# Copiá este archivo a .env y completá los valores. NO subas .env al repo.

# --- Supabase ---
# Project Settings → API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
# service_role key — solo para ingesta y Edge Function (NUNCA en el frontend)
SUPABASE_SERVICE_KEY=tu-service-role-key
# anon key — para el frontend
SUPABASE_ANON_KEY=tu-anon-key

# --- Groq (LLM) ---
# https://console.groq.com/keys — free tier, sin tarjeta
GROQ_API_KEY=tu-groq-api-key
